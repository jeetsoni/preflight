# --- Pre-Flight configuration ---
# The app depends on neither provider directly, so you can switch freely.

# Active provider: "google" (Gemini) or "anthropic" (Claude)
AI_PROVIDER=google
# Model id for the active provider (e.g. gemini-2.5-flash, gemini-2.5-pro, claude-sonnet-4-6)
AI_MODEL=gemini-2.5-flash

# Google Generative AI (Gemini) API key — used when AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=

# Anthropic API key — used when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
